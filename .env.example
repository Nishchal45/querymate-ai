# ──────────────────────────────────────────────
# QueryMate AI — Environment Variables
# ──────────────────────────────────────────────
# Copy this file: cp .env.example .env
# Then fill in your values below.

# ── App ──
APP_ENV=development
APP_PORT=8000
LOG_LEVEL=INFO

# ── OpenAI ──
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# ── Application Database (query history, app metadata) ──
APP_DB_USER=querymate
APP_DB_PASSWORD=querymate_secret
APP_DB_NAME=querymate_app
APP_DB_HOST=app_db
APP_DB_PORT=5432
APP_DATABASE_URL=postgresql+asyncpg://${APP_DB_USER}:${APP_DB_PASSWORD}@${APP_DB_HOST}:${APP_DB_PORT}/${APP_DB_NAME}

# ── Target Database (the DB users query with natural language) ──
TARGET_DB_USER=demo_user
TARGET_DB_PASSWORD=demo_secret
TARGET_DB_NAME=ecommerce_demo
TARGET_DB_HOST=target_db
TARGET_DB_PORT=5432
TARGET_DATABASE_URL=postgresql://${TARGET_DB_USER}:${TARGET_DB_PASSWORD}@${TARGET_DB_HOST}:${TARGET_DB_PORT}/${TARGET_DB_NAME}

# ── Redis (query caching + rate limiting) ──
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0

# ── Query Safety ──
QUERY_TIMEOUT_SECONDS=10
MAX_RESULT_ROWS=1000

# ── Cache TTL (seconds) ──
CACHE_TTL_NL_SQL=3600
CACHE_TTL_SQL_RESULTS=300

# ── Frontend ──
VITE_API_URL=http://localhost:8000
